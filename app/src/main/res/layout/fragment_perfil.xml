<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <ImageView
                android:id="@+id/btnBackPerfil"
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:background="@drawable/account_circle"
                android:padding="5dp"
                android:src="@drawable/baseline_person_24" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Mi Perfil"
                android:textColor="#000000"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:layout_width="130dp"
            android:layout_height="130dp"
            android:layout_gravity="center"
            app:cardCornerRadius="25dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">
                <ImageView
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:src="@drawable/account_circle" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#149BC3"
                    android:gravity="center"
                    android:padding="5dp"
                    android:text="Subir Foto"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:alignmentMode="alignMargins"
            android:layout_marginTop="10dp">

            <LinearLayout android:layout_width="0dp" android:layout_columnWeight="1" android:orientation="vertical" android:padding="5dp">
                <TextView android:text="Nombre" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <EditText android:id="@+id/etNombre" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Carlos" android:textSize="15sp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_columnWeight="1" android:orientation="vertical" android:padding="5dp">
                <TextView android:text="Apellidos" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <EditText android:id="@+id/etApellidos" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Rodríguez" android:textSize="15sp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_columnWeight="1" android:orientation="vertical" android:padding="5dp">
                <TextView android:text="Usuario" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <EditText android:id="@+id/etUser" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="crodriguez" android:textSize="15sp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_columnWeight="1" android:orientation="vertical" android:padding="5dp">
                <TextView android:text="NIT" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <EditText android:id="@+id/etNit" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="0000-000000-000-0" android:textSize="15sp"/>
            </LinearLayout>
        </GridLayout>

        <TextView android:text="Fecha de Registro" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="15dp"/>
        <EditText android:id="@+id/etFecha" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="DD/MM/YYYY" android:drawableEnd="@android:drawable/ic_menu_my_calendar"/>

        <TextView android:text="Teléfono" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="15dp"/>
        <EditText android:id="@+id/etTelefono" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="7777-7777" android:inputType="phone"/>

        <TextView android:text="Rol" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="15dp"/>
        <EditText android:id="@+id/etRol" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Administrador" android:enabled="false"/>

        <TextView android:text="Correo Corporativo" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="15dp"/>
        <EditText android:id="@+id/etCorreo" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="carlos.rodriguez@cotman.sv" android:inputType="textEmailAddress"/>

        <Button
            android:id="@+id/btnActualizarPerfil"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="20dp"
            android:backgroundTint="#149BC3"
            android:text="ACTUALIZAR PERFIL"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            app:cornerRadius="15dp" />

    </LinearLayout>
</ScrollView>